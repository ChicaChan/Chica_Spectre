---
export const prerender = false;

import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import {
	getPublicDashboardView,
	type DashboardPanelView,
	type PublicDashboardView,
} from '../lib/directus-insights';

const dashboard = await getPublicDashboardView();

function panelGridStyle(panel: DashboardPanelView) {
	return `grid-column:${panel.positionX} / span ${panel.width};grid-row:${panel.positionY} / span ${panel.height};`;
}

function resolveDashboardColumns(panels: DashboardPanelView[]) {
	const maxColumn = panels.reduce(
		(result, panel) => Math.max(result, panel.positionX + panel.width - 1),
		24,
	);
	return Math.max(24, maxColumn);
}

function normalizePanelColor(color: string | null | undefined) {
	if (!color) return 'var(--primary)';
	if (color === 'primary' || color === 'var(--theme--primary)') return 'var(--primary)';
	if (color === 'success' || color === 'var(--theme--success)') return 'var(--success)';
	if (color === 'warning' || color === 'var(--theme--warning)') return '#ffb84d';
	if (color === 'danger' || color === 'var(--theme--danger)') return '#ff6b7a';
	return color;
}

function buildLineChart(points: Array<{ label: string; value: number }>) {
	const width = 720;
	const height = 260;
	const paddingX = 28;
	const paddingY = 24;
	const usableWidth = width - paddingX * 2;
	const usableHeight = height - paddingY * 2;
	const max = Math.max(...points.map((point) => point.value), 1);

	const chartPoints = points.map((point, index) => {
		const x =
			points.length === 1
				? width / 2
				: paddingX + (usableWidth * index) / Math.max(points.length - 1, 1);
		const y = height - paddingY - (point.value / max) * usableHeight;
		return { ...point, x, y };
	});

	const polyline = chartPoints.map((point) => `${point.x},${point.y}`).join(' ');
	const areaPath =
		chartPoints.length > 0
			? `M ${chartPoints[0].x} ${height - paddingY} L ${chartPoints
					.map((point) => `${point.x} ${point.y}`)
					.join(' L ')} L ${chartPoints[chartPoints.length - 1].x} ${height - paddingY} Z`
			: '';

	return {
		width,
		height,
		paddingX,
		paddingY,
		max,
		chartPoints,
		polyline,
		areaPath,
	};
}

function hasDashboardData(value: PublicDashboardView | null): value is PublicDashboardView {
	return value !== null;
}
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead
			title={`${SITE_TITLE} · 仪表盘`}
			description="在 Directus 中维护的公开仪表盘，会同步渲染到博客前台。"
		/>
	</head>
	<body>
		<Header />
		<main class="dashboard-main">
			{
				hasDashboardData(dashboard) ? (
					<>
						<section
							class="dashboard-grid"
							style={`--dashboard-columns:${resolveDashboardColumns(dashboard.panels)};`}
						>
							{
								dashboard.panels.map((panel) => {
									const accent = normalizePanelColor(panel.color);

									if (panel.kind === 'label') {
										return (
											<article
												class="card dashboard-panel label-panel"
												style={`${panelGridStyle(panel)}--panel-accent:${accent};white-space:${panel.whiteSpace};`}
											>
												<p class="label">分区</p>
												<h2>{panel.text}</h2>
											</article>
										);
									}

									if (panel.kind === 'metric') {
										return (
											<article
												class="card dashboard-panel metric-panel"
												style={`${panelGridStyle(panel)}--panel-accent:${accent};`}
											>
												{
													panel.showHeader && (
														<div class="panel-head">
															<div>
																<p class="label">指标</p>
																<h2>{panel.name}</h2>
															</div>
															{panel.note && <p class="panel-note">{panel.note}</p>}
														</div>
													)
												}
												<div class="metric-value">{panel.value}</div>
											</article>
										);
									}

									if (panel.kind === 'list') {
										return (
											<article
												class="card dashboard-panel list-panel"
												style={`${panelGridStyle(panel)}--panel-accent:${accent};`}
											>
												{
													panel.showHeader && (
														<div class="panel-head">
															<div>
																<p class="label">列表</p>
																<h2>{panel.name}</h2>
															</div>
															{panel.note && <p class="panel-note">{panel.note}</p>}
														</div>
													)
												}
												<ol class="post-list">
													{
														panel.items.map((item, index) => (
															<li>
																<span class="list-index">
																	{String(index + 1).padStart(2, '0')}
																</span>
																<div class="list-copy">
																	{item.href ? (
																		<a href={item.href}>{item.label}</a>
																	) : (
																		<strong>{item.label}</strong>
																	)}
																	{item.meta && <span>{item.meta}</span>}
																</div>
															</li>
														))
													}
												</ol>
											</article>
										);
									}

									if (panel.kind === 'time-series') {
										const chart = buildLineChart(panel.points);

										return (
											<article
												class="card dashboard-panel chart-panel"
												style={`${panelGridStyle(panel)}--panel-accent:${accent};`}
											>
												{
													panel.showHeader && (
														<div class="panel-head">
															<div>
																<p class="label">趋势</p>
																<h2>{panel.name}</h2>
															</div>
															{panel.note && <p class="panel-note">{panel.note}</p>}
														</div>
													)
												}

												{
													panel.points.length > 0 ? (
														<>
															<svg
																class="trend-chart"
																viewBox={`0 0 ${chart.width} ${chart.height}`}
																role="img"
																aria-label={panel.name}
															>
																<defs>
																	<linearGradient
																		id={`chart-gradient-${panel.id}`}
																		x1="0"
																		x2="0"
																		y1="0"
																		y2="1"
																	>
																		<stop offset="0%" stop-color="var(--panel-accent)" stop-opacity="0.35"></stop>
																		<stop offset="100%" stop-color="var(--panel-accent)" stop-opacity="0"></stop>
																	</linearGradient>
																</defs>

																{
																	[0, 0.25, 0.5, 0.75, 1].map((ratio) => {
																		const y =
																			chart.height -
																			chart.paddingY -
																			(chart.height - chart.paddingY * 2) * ratio;
																		return (
																			<line
																				x1={chart.paddingX}
																				x2={chart.width - chart.paddingX}
																				y1={y}
																				y2={y}
																				class="chart-gridline"
																			></line>
																		);
																	})
																}

																<path
																	d={chart.areaPath}
																	fill={`url(#chart-gradient-${panel.id})`}
																></path>
																<polyline
																	points={chart.polyline}
																	fill="none"
																	stroke="var(--panel-accent)"
																	stroke-width="4"
																	stroke-linecap="round"
																	stroke-linejoin="round"
																></polyline>
																{
																	chart.chartPoints.map((point) => (
																		<g>
																			<circle
																				cx={point.x}
																				cy={point.y}
																				r="6"
																				fill="var(--panel-accent)"
																			></circle>
																			<circle
																				cx={point.x}
																				cy={point.y}
																				r="12"
																				fill="transparent"
																				stroke="rgba(255,255,255,0.08)"
																			></circle>
																		</g>
																	))
																}
															</svg>

															<ul class="chart-legend">
																{
																	panel.points.map((point) => (
																		<li>
																			<span>{point.label}</span>
																			<strong>{point.value}</strong>
																		</li>
																	))
																}
															</ul>
														</>
													) : (
														<p class="empty-copy">当前还没有可绘制的时间序列数据。</p>
													)
												}
											</article>
										);
									}

									return (
										<article
											class="card dashboard-panel unsupported-panel"
											style={`${panelGridStyle(panel)}--panel-accent:${accent};`}
										>
											<p class="label">未支持</p>
											<h2>{panel.name}</h2>
											<p>当前前台还没有实现 {panel.type} 面板的公开渲染。</p>
										</article>
									);
								})
							}
						</section>
					</>
				) : (
					<section class="card empty-state">
						<p class="label">No Public Dashboard</p>
						<h1>还没有可公开展示的 Directus 仪表盘</h1>
						<p>
							先在 Directus 中创建 dashboard 和 panel，并授予对应 dashboard / panels 的只读公开权限，
							博客前台就会自动同步展示。
						</p>
					</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	.dashboard-main {
		width: min(1380px, calc(100% - 2rem));
	}

	.dashboard-grid {
		display: grid;
		grid-template-columns: repeat(var(--dashboard-columns, 24), minmax(0, 1fr));
		grid-auto-rows: 2.8rem;
		gap: 1rem;
	}

	.dashboard-panel {
		--panel-accent: var(--primary);
		display: flex;
		flex-direction: column;
		height: 100%;
		padding: 1.15rem;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent 35%),
			linear-gradient(165deg, var(--panel) 0%, var(--panel-strong) 100%);
		border-color: color-mix(in srgb, var(--panel-accent), var(--border) 78%);
	}

	.panel-head {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.panel-head h2 {
		margin-bottom: 0;
		font-size: 1.15rem;
	}

	.panel-note {
		max-width: 20rem;
		margin: 0;
		font-size: 0.88rem;
	}

	.label-panel {
		justify-content: center;
		background:
			linear-gradient(135deg, color-mix(in srgb, var(--panel-accent), transparent 85%), transparent 42%),
			linear-gradient(165deg, var(--panel) 0%, var(--panel-strong) 100%);
	}

	.label-panel h2 {
		max-width: 22rem;
		font-size: clamp(1.8rem, 3vw, 2.4rem);
		line-height: 1.15;
		margin-bottom: 0;
	}

	.metric-panel {
		justify-content: space-between;
	}

	.metric-value {
		font-size: clamp(2.2rem, 5vw, 3.6rem);
		line-height: 1;
		font-weight: 800;
		letter-spacing: -0.04em;
		color: white;
		text-shadow: 0 0 22px color-mix(in srgb, var(--panel-accent), transparent 70%);
	}

	.list-panel ol {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
	}

	.post-list li {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.9rem;
		align-items: flex-start;
		padding-bottom: 0.85rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}

	.post-list li:last-child {
		border-bottom: 0;
		padding-bottom: 0;
	}

	.list-index {
		color: var(--panel-accent);
		font-weight: 700;
		font-size: 0.82rem;
		padding-top: 0.15rem;
	}

	.list-copy {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.list-copy a,
	.list-copy strong {
		color: var(--text);
		font-size: 0.96rem;
	}

	.list-copy span {
		color: var(--muted);
		font-size: 0.85rem;
	}

	.chart-panel {
		justify-content: space-between;
	}

	.trend-chart {
		width: 100%;
		height: auto;
		margin-bottom: 0.9rem;
	}

	.chart-gridline {
		stroke: rgba(255, 255, 255, 0.08);
		stroke-width: 1;
	}

	.chart-legend {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
		gap: 0.65rem;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	.chart-legend li {
		padding: 0.7rem 0.8rem;
		border: 1px solid rgba(255, 255, 255, 0.06);
		background: rgba(255, 255, 255, 0.03);
	}

	.chart-legend span {
		display: block;
		font-size: 0.8rem;
		color: var(--muted);
	}

	.chart-legend strong {
		display: block;
		margin-top: 0.25rem;
		font-size: 1.1rem;
	}

	.unsupported-panel,
	.empty-state {
		align-items: flex-start;
	}

	.empty-copy {
		margin: 0;
	}

	@media (max-width: 1100px) {
		.dashboard-main {
			width: min(1380px, calc(100% - 1rem));
		}

		.panel-head {
			flex-direction: column;
			align-items: flex-start;
		}

		.dashboard-grid {
			grid-template-columns: 1fr;
			grid-auto-rows: auto;
		}

		.dashboard-panel {
			grid-column: auto !important;
			grid-row: auto !important;
			min-height: 16rem;
		}
	}
</style>
