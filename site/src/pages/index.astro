---
import AiConsole from '../components/AiConsole.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { formatPostDate, listPosts } from '../lib/cms';

const posts = await listPosts(5);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="grid-2">
				<AiConsole />

				<section class="card stack">
					<p class="label">Latest Logs</p>
					<h2>最新文章</h2>
					{
						posts.length > 0 ? (
							posts.map((post) => {
								const date = formatPostDate(post);
								return (
									<a class="post-card" href={`/blog/${post.slug}/`}>
										<h3>{post.title}</h3>
										{date && (
											<p class="meta">
												<FormattedDate date={date} />
											</p>
										)}
										{post.excerpt && <p>{post.excerpt}</p>}
									</a>
								);
							})
						) : (
							<p>
								还没有文章。请在 Directus 的 <code>posts</code> 集合中添加内容。
							</p>
						)
					}
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>
