---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { formatPostDate, listPosts } from '../../lib/cms';

const posts = await listPosts();
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`${SITE_TITLE} · 博客`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="card stack">
				<p class="label">Blog Archive</p>
				<h1>博客文章</h1>
				{
					posts.length > 0 ? (
						posts.map((post) => {
							const date = formatPostDate(post);
							return (
								<a class="post-card" href={`/blog/${post.slug}/`}>
									<h3>{post.title}</h3>
									{date && (
										<p class="meta">
											<FormattedDate date={date} />
										</p>
									)}
									{post.excerpt && <p>{post.excerpt}</p>}
								</a>
							);
						})
					) : (
						<p>Directus 中还没有文章。请创建 <code>posts</code> 集合并添加内容。</p>
					)
				}
			</section>
		</main>
		<Footer />
	</body>
</html>
